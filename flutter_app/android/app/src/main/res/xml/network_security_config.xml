<?xml version="1.0" encoding="utf-8"?>
<!--
  HTTPS 전용 네트워크 보안 설정
  - cleartext(HTTP) 트래픽 전면 차단
  - 모델 다운로드 허용 도메인 명시적 고정
  - 앱 자체 통신 없음 (완전 오프라인 번역/음성 인식)
-->
<network-security-config>

    <!-- 기본: HTTPS 전용, 시스템 인증서만 신뢰 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- GitHub Releases — 번역 모델 다운로드 -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">objects.githubusercontent.com</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>

    <!-- alphacephei — Vosk 음성 인식 모델 다운로드 -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">alphacephei.com</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>

</network-security-config>
